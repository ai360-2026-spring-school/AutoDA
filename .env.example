TIMEWEB_API_TOKEN=your_token_here
TIMEWEB_AGENT_ID=your_agent_id_here
TIMEWEB_MODEL=timeweb-agent

# optional
TIMEWEB_BASE_URL=https://agent.timeweb.cloud/api/v1/cloud-ai/agents/your_agent_id_here/v1

# --- GigaChat ---
GIGACHAT_CREDENTIALS=your_base64_creds_here
GIGACHAT_MODEL=GigaChat-2-Max
GIGACHAT_SCOPE=GIGACHAT_API_CORP
GIGACHAT_VERIFY_SSL=false